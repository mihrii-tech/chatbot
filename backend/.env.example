# ============================================
# VELOHOUSE CHATBOT - Environment Variables
# ============================================

# Google Gemini AI
GEMINI_API_KEY=DIN_GEMINI_API_KEY_HER

# Shopify (udfyld når du er klar til at teste med rigtige data)
SHOPIFY_STORE_DOMAIN=velohouse.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=din_storefront_token_her

# Email (Gmail SMTP)
# Brug en Gmail App Password: Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=din.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_TO=contact@velohouse.dk
EMAIL_FROM=Velohouse Chatbot <din.email@gmail.com>

# Server
PORT=3001
NODE_ENV=development

# CORS - tilføj din Shopify domain her (produktion)
CORS_ORIGINS=http://localhost:3001,http://localhost:5500,https://velohouse.dk,https://www.velohouse.dk

# Brug mock data til test (sæt til false når Shopify er klar)
USE_MOCK_PRODUCTS=true
